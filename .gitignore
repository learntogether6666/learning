# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor / IDE
.vscode/
.idea/
*.swp
*~
.obsidian/workspace*

# Scratch / local-only
scratch/
tmp/
*.local
.env

# Secrets — NEVER commit (tokens, credentials)
.token
*.token
.personal-credentials
*credentials*
.secrets/

# Lab artifacts (don't commit generated data / volumes)
**/data/
**/_volumes/
**/*.log
**/node_modules/

# NOTE: Claude's machine-local memory (~/.claude) is intentionally NOT in this repo.
